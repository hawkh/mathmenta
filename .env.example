# Anthropic API Key (required for Claude models, leave empty to use Ollama)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama Configuration (used if ANTHROPIC_API_KEY is empty or USE_OLLAMA=true)
OLLAMA_BASE_URL=http://localhost:11434
USE_OLLAMA=true

# OpenAI API Key (optional, for Whisper speech recognition)
OPENAI_API_KEY=your_openai_api_key_here

# Model Configuration
# For Ollama: llama3.3, llama3.2, mistral, mixtral, etc.
# For Anthropic: claude-sonnet-4-20250514, claude-3-5-sonnet-20241022, etc.
DEFAULT_MODEL=llama3.3
EMBEDDING_MODEL=all-MiniLM-L6-v2

# HITL Confidence Thresholds
OCR_CONFIDENCE_THRESHOLD=0.75
ASR_CONFIDENCE_THRESHOLD=0.75
VERIFIER_CONFIDENCE_THRESHOLD=0.70
