# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional – needed for audio transcription (Whisper API)
OPENAI_API_KEY=your_openai_api_key_here

# Vector store path (default: ./rag/faiss_index)
FAISS_INDEX_PATH=./rag/faiss_index

# Memory store path (default: ./memory/memory_store.json)
MEMORY_STORE_PATH=./memory/memory_store.json

# HITL confidence thresholds (0.0 – 1.0)
OCR_CONFIDENCE_THRESHOLD=0.75
SOLVER_CONFIDENCE_THRESHOLD=0.70

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of RAG chunks to retrieve
RAG_TOP_K=5
